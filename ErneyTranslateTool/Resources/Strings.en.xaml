    <!-- Glossary -->
    <sys:String x:Key="Strings.Glossary.Title">Proper-noun glossary</sys:String>
    <sys:String x:Key="Strings.Glossary.Help">Add a rule "Source → Translation" — after the translator returns its result, the app substitutes every match in the final text. Useful for character names, locations, items in games that auto-translate mangles (e.g. "Geralt" → "Геральт", "Kaer Morhen" → "Каэр Морхен"). Rules are scoped to the target language: "RU" rules only fire when translating to Russian.</sys:String>
    <sys:String x:Key="Strings.Glossary.UseToggle">Use glossary</sys:String>
    <sys:String x:Key="Strings.Glossary.UseToggle.Tooltip">Master toggle — turn off to disable all replacements without deleting rules</sys:String>
