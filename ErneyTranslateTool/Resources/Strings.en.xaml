    <!-- Profiles -->
    <sys:String x:Key="Strings.Profiles.Title">Per-game profiles</sys:String>
    <sys:String x:Key="Strings.Profiles.Active">Active: </sys:String>
    <sys:String x:Key="Strings.Profiles.Help">A profile is a bundle of settings (OCR engine, languages, translation provider, overlay font and colours, glossary toggle) for a specific game. When you pick a window on "Main" and click "Start", the app finds the first profile whose "Pattern" matches the window title or process name and applies its settings. If none match — the "Default" profile is used. On first launch for a new game, a profile is created automatically.</sys:String>
    <sys:String x:Key="Strings.Profiles.AddBlank">Add blank</sys:String>
    <sys:String x:Key="Strings.Profiles.CreateFromCurrent">Create from current settings</sys:String>
    <sys:String x:Key="Strings.Profiles.CreateFromCurrent.Tooltip">Snapshots the current settings (Translation Settings + Overlay Settings tabs) into a new profile</sys:String>
    <sys:String x:Key="Strings.Profiles.ColName">Name</sys:String>
    <sys:String x:Key="Strings.Profiles.ColPattern">Match pattern</sys:String>
    <sys:String x:Key="Strings.Profiles.ColPattern.Tooltip">Substring (case-insensitive) to look for in the window title or process name</sys:String>
    <sys:String x:Key="Strings.Profiles.ColMatchExe">Match exe</sys:String>
    <sys:String x:Key="Strings.Profiles.ColMatchExe.Tooltip">If on, the pattern is checked against the process name; otherwise the window title</sys:String>
    <sys:String x:Key="Strings.Profiles.ColTarget">Target</sys:String>
    <sys:String x:Key="Strings.Profiles.ColOcr">OCR</sys:String>
    <sys:String x:Key="Strings.Profiles.ColProvider">Provider</sys:String>
