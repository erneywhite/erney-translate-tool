<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Light theme palette ===== -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F7"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="AlternateRowBrush" Color="#EEF1F5"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#6D28D9"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#1F2937"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#9CA3AF"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#E5E7EB"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#059669"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#2563EB"/>

    <SolidColorBrush x:Key="HeaderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>

</ResourceDictionary>
