<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Dark theme palette (default) ===== -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="#2A2A3E"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="#151520"/>
    <SolidColorBrush x:Key="AlternateRowBrush" Color="#252535"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#6D28D9"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#4B5563"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#6B7280"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#374151"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#4B5563"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#3B82F6"/>

    <SolidColorBrush x:Key="HeaderBrush" Color="#2D2D44"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2D2D44"/>

</ResourceDictionary>
