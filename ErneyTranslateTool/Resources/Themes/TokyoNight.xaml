<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Tokyo Night — modern "cyberpunk" navy =====
         Inspired by enkia/tokyo-night-vscode-theme. Deep blue-black
         backgrounds with electric blue + lavender accents. -->

    <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1B26"/>
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="#24283B"/>
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="#16161E"/>
    <SolidColorBrush x:Key="AlternateRowBrush" Color="#1F2335"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#7AA2F7"/>                <!-- electric blue -->
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#92B6FF"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#BB9AF7"/>           <!-- soft lavender -->
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#1A1B26"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#414868"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#565F89"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#C0CAF5"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#C0CAF5"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9AA5CE"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#565F89"/>

    <SolidColorBrush x:Key="BorderBrush" Color="#33467C"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="#414868"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#9ECE6A"/>                <!-- lime green -->
    <SolidColorBrush x:Key="WarningBrush" Color="#E0AF68"/>                <!-- amber -->
    <SolidColorBrush x:Key="ErrorBrush" Color="#F7768E"/>                  <!-- coral -->
    <SolidColorBrush x:Key="InfoBrush" Color="#7DCFFF"/>                   <!-- cyan -->

    <SolidColorBrush x:Key="HeaderBrush" Color="#24283B"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#24283B"/>

</ResourceDictionary>
