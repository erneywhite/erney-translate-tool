<Application x:Class="ErneyTranslateTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Theme palette: must come before Styles.xaml so style
                     setters that reference brushes via DynamicResource
                     resolve correctly. ThemeManager swaps this dictionary
                     at runtime when the user picks a different theme. -->
                <ResourceDictionary Source="Resources/Themes/Dark.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Strings.ru.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
