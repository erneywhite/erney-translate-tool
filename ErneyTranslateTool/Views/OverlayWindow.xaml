<Window x:Class="ErneyTranslateTool.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Left="0" Top="0" Width="400" Height="100">

    <Grid>
        <Border x:Name="TranslationBorder"
                Background="#CC000000"
                CornerRadius="6"
                Padding="10,6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Visibility="Collapsed">
            <TextBlock x:Name="TranslationText"
                       Foreground="White"
                       FontSize="14"
                       FontFamily="Segoe UI"
                       TextWrapping="Wrap"
                       MaxWidth="600" />
        </Border>
    </Grid>
</Window>
