<Window x:Class="ErneyTranslateTool.Views.Dialogs.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Strings.UpdateDlg.Title}"
        Width="640" Height="560"
        MinWidth="500" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24,20,24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock x:Name="TitleText"
                       Text="{DynamicResource Strings.UpdateDlg.Heading}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="SubtitleText"
                       Margin="0,4,0,0"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Notes label -->
        <TextBlock Grid.Row="1"
                   Text="{DynamicResource Strings.UpdateDlg.WhatsNew}"
                   Margin="0,16,0,6"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <!-- Notes scroller -->
        <Border Grid.Row="2"
                Background="{DynamicResource BackgroundDarkBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14,12">
                <TextBlock x:Name="NotesText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="13"
                           LineHeight="20"/>
            </ScrollViewer>
        </Border>

        <!-- Progress (hidden until download starts) -->
        <StackPanel Grid.Row="3" x:Name="ProgressPanel"
                    Margin="0,14,0,0"
                    Visibility="Collapsed">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="ProgressLabel"
                           Text="{DynamicResource Strings.UpdateDlg.Downloading}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"/>
                <TextBlock Grid.Column="1" x:Name="ProgressPercent"
                           Text="0%"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"/>
            </Grid>
            <ProgressBar x:Name="DownloadProgress"
                         Height="8"
                         Minimum="0" Maximum="1"
                         Value="0"
                         Foreground="{DynamicResource PrimaryBrush}"
                         Background="{DynamicResource BackgroundDarkBrush}"
                         BorderThickness="0"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="OpenPageButton"
                    Content="{DynamicResource Strings.UpdateDlg.OpenPage}"
                    Padding="12,7"
                    HorizontalAlignment="Left"
                    Click="OnOpenPageClick"/>

            <Button Grid.Column="1" x:Name="LaterButton"
                    Content="{DynamicResource Strings.UpdateDlg.Later}"
                    Padding="14,7"
                    Margin="0,0,8,0"
                    Click="OnLaterClick"/>

            <Button Grid.Column="2" x:Name="InstallButton"
                    Content="{DynamicResource Strings.UpdateDlg.InstallNow}"
                    Padding="18,7"
                    FontWeight="SemiBold"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource PrimaryForegroundBrush}"
                    BorderBrush="{DynamicResource PrimaryHoverBrush}"
                    BorderThickness="1"
                    Click="OnInstallClick"/>

            <Button Grid.Column="3" x:Name="CancelButton"
                    Content="{DynamicResource Strings.Common.Cancel}"
                    Padding="14,7"
                    Margin="8,0,0,0"
                    Visibility="Collapsed"
                    Click="OnCancelClick"/>
        </Grid>
    </Grid>
</Window>
