<Window x:Class="ErneyTranslateTool.Views.Dialogs.AddToGlossaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Strings.AddToGlossary.Title}"
        Width="560" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Strings.AddToGlossary.Heading}"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1"
                   Text="{DynamicResource Strings.AddToGlossary.Help}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- Source: prefilled with full sentence; user trims to the proper noun. -->
        <TextBlock Grid.Row="2"
                   Text="{DynamicResource Strings.AddToGlossary.Source}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="SourceBox"
                 Grid.Row="3"
                 FontFamily="Consolas"
                 Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4"
                   Text="{DynamicResource Strings.AddToGlossary.Target}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,4"/>
        <TextBox x:Name="TargetBox"
                 Grid.Row="5"
                 FontFamily="Consolas"
                 Margin="0,0,0,12"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,16">
            <CheckBox x:Name="WholeWordCheck"
                      Content="{DynamicResource Strings.AddToGlossary.WholeWord}"
                      IsChecked="True"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      VerticalAlignment="Center"
                      Margin="0,0,18,0"/>
            <CheckBox x:Name="CaseCheck"
                      Content="{DynamicResource Strings.AddToGlossary.CaseSensitive}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Strings.Common.Cancel}"
                    Padding="14,6" MinWidth="90"
                    Margin="0,0,8,0"
                    Click="OnCancelClick"/>
            <Button x:Name="SaveButton"
                    Content="{DynamicResource Strings.Common.Save}"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Padding="14,6" MinWidth="120"
                    IsDefault="True"
                    Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
