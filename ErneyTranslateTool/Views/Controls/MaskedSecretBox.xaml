<UserControl x:Class="ErneyTranslateTool.Views.Controls.MaskedSecretBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Two stacked text boxes: PasswordBox-style masked one and a plain
             TextBox revealed when the user toggles the eye. They share the
             Secret dependency-property so flipping visibility doesn't lose
             the value. -->
        <TextBox x:Name="MaskedBox"
                 Grid.Column="0"
                 FontFamily="Consolas"
                 IsTabStop="True"
                 Visibility="Visible">
            <!-- Render every character as a black circle. Setter doesn't
                 affect IME / paste / selection — feels like a PasswordBox
                 but keeps two-way binding to a string. -->
            <TextBox.Resources>
                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                    <Setter Property="FontFamily" Value="Consolas"/>
                </Style>
            </TextBox.Resources>
        </TextBox>

        <TextBox x:Name="PlainBox"
                 Grid.Column="0"
                 FontFamily="Consolas"
                 IsTabStop="True"
                 Visibility="Collapsed"/>

        <!-- Eye toggle. Shows for ~3 seconds while the user verifies their
             pasted key, then they click again to mask. -->
        <ToggleButton x:Name="RevealToggle"
                      Grid.Column="1"
                      Margin="6,0,0,0"
                      Padding="10,6"
                      Width="44"
                      Background="Transparent"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      Cursor="Hand"
                      Checked="OnRevealChanged"
                      Unchecked="OnRevealChanged"
                      ToolTip="Показать/скрыть значение">
            <TextBlock x:Name="EyeIcon" Text="👁" FontSize="14"/>
        </ToggleButton>
    </Grid>
</UserControl>
