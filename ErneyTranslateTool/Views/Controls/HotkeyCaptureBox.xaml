<UserControl x:Class="ErneyTranslateTool.Views.Controls.HotkeyCaptureBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="240"
             Focusable="True"
             FocusVisualStyle="{x:Null}"
             LostKeyboardFocus="OnLostKeyboardFocus">
    <!-- Click anywhere on the surface to start capturing the next key combo.
         While capturing, all key events are intercepted by PreviewKeyDown
         in code-behind so Tab/Enter/Esc don't leak to other controls. -->
    <Border x:Name="CaptureSurface"
            Background="{DynamicResource InputBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            MinHeight="32"
            Cursor="Hand"
            MouseLeftButtonDown="OnSurfaceMouseDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="DisplayText"
                       Grid.Column="0"
                       Margin="10,6"
                       VerticalAlignment="Center"
                       FontFamily="Consolas"
                       FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Text="—"/>

            <!-- Small "✕" to clear the hotkey without going through capture
                 mode (useful when the user wants the hotkey unset entirely,
                 e.g. removing the optional Pause hotkey). -->
            <Button x:Name="ClearButton"
                    Grid.Column="1"
                    Margin="0,3,4,3"
                    Padding="8,0"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource TextSecondaryBrush}"
                    FontFamily="Segoe MDL2 Assets"
                    Content="&#xE894;"
                    FontSize="10"
                    Visibility="Collapsed"
                    Cursor="Hand"
                    Click="OnClearClick"/>
        </Grid>
    </Border>
</UserControl>
