<UserControl x:Class="ErneyTranslateTool.Views.Tabs.ProfilesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Strings.Profiles.Title}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBlock Text="{DynamicResource Strings.Profiles.Active}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveProfileName}"
                           Foreground="{DynamicResource PrimaryBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{DynamicResource Strings.Profiles.Help}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,12"/>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{DynamicResource Strings.Profiles.AddBlank}"
                    Command="{Binding AddBlankCommand}"
                    Padding="14,6" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="{DynamicResource Strings.Profiles.CreateFromCurrent}"
                    Command="{Binding CreateFromCurrentCommand}"
                    Padding="14,6"
                    ToolTip="{DynamicResource Strings.Profiles.CreateFromCurrent.Tooltip}"/>

            <Button Grid.Column="3" Content="{DynamicResource Strings.Common.Import}"
                    Command="{Binding ImportCommand}"
                    Padding="14,6" Margin="0,0,8,0"/>
            <Button Grid.Column="4" Content="{DynamicResource Strings.Common.Export}"
                    Command="{Binding ExportCommand}"
                    Padding="14,6" Margin="0,0,8,0"/>
            <Button Grid.Column="5" Content="{DynamicResource Strings.Common.Save}"
                    Command="{Binding SaveCommand}"
                    Padding="18,6" FontWeight="SemiBold"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource PrimaryForegroundBrush}"/>
        </Grid>

        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Profiles}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  SelectionUnit="Cell"
                  GridLinesVisibility="Horizontal"
                  Background="{DynamicResource InputBackgroundBrush}"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  RowBackground="{DynamicResource InputBackgroundBrush}"
                  AlternatingRowBackground="{DynamicResource AlternateRowBrush}"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource Strings.Profiles.ColName}"
                                    Binding="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                    Width="*" MinWidth="120"/>
                <DataGridTextColumn Header="{DynamicResource Strings.Profiles.ColPattern}"
                                    Binding="{Binding MatchPattern, UpdateSourceTrigger=LostFocus}"
                                    Width="*" MinWidth="140"
                                    ToolTipService.ToolTip="{DynamicResource Strings.Profiles.ColPattern.Tooltip}"/>
                <DataGridCheckBoxColumn Header="{DynamicResource Strings.Profiles.ColMatchExe}"
                                        Binding="{Binding MatchByProcessName, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"
                                        ToolTipService.ToolTip="{DynamicResource Strings.Profiles.ColMatchExe.Tooltip}"/>
                <DataGridTextColumn Header="{DynamicResource Strings.Profiles.ColTarget}"
                                    Binding="{Binding TargetLanguage, UpdateSourceTrigger=LostFocus}"
                                    Width="50"/>
                <DataGridTextColumn Header="{DynamicResource Strings.Profiles.ColOcr}"
                                    Binding="{Binding OcrEngine, UpdateSourceTrigger=LostFocus}"
                                    Width="90"/>
                <DataGridTextColumn Header="{DynamicResource Strings.Profiles.ColProvider}"
                                    Binding="{Binding TranslationProvider, UpdateSourceTrigger=LostFocus}"
                                    Width="90"/>
                <DataGridTemplateColumn Header="" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource Strings.Common.Apply}"
                                        Padding="8,3" Margin="0,0,4,0"
                                        Command="{Binding DataContext.ApplyNowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Strings.Profiles.Apply.Tooltip}"/>
                                <Button Content="{DynamicResource Strings.Common.Delete}"
                                        Padding="8,3"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="IsEnabled" Value="True"/>
                                            <Style.Triggers>
                                                <!-- Default profile is the always-present fallback -
                                                     gray out delete to make this obvious in the UI. -->
                                                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                    <Setter Property="ToolTip" Value="{DynamicResource Strings.Profiles.DefaultLockedTooltip}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       FontSize="11"/>
            <Button Grid.Column="1" Content="{DynamicResource Strings.Common.Refresh}"
                    Command="{Binding RefreshCommand}"
                    Padding="12,5"/>
        </Grid>
    </Grid>
</UserControl>
