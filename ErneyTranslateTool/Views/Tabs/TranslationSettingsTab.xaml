<UserControl x:Class="ErneyTranslateTool.Views.Tabs.TranslationSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="Настройки перевода"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,20"/>

            <GroupBox Header="DeepL API" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10">
                        Бесплатный ключ DeepL API: 500 000 символов в месяц, карта не требуется.
                        Регистрация: https://www.deepl.com/pro-api (Sign up for free).
                        Ключ заканчивается на ":fx".
                    </TextBlock>

                    <TextBlock Text="API-ключ DeepL:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                        <Button Grid.Column="1"
                                Content="Проверить ключ"
                                Command="{Binding TestApiCommand}"
                                Padding="12,6" Margin="10,0,0,0"/>
                    </Grid>

                    <TextBlock Text="{Binding TestApiStatus}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Целевой язык перевода" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <ComboBox ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding SelectedTargetLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="280" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Языковые пакеты OCR (Windows.Media.OCR)"
                      Style="{DynamicResource DarkGroupBoxStyle}"
                      Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="Установленные пакеты:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding InstalledOcrLanguages}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,10,0,0">
                        Для распознавания японского/китайского/корейского установите соответствующий
                        языковой пакет: Параметры Windows → Время и язык → Язык и регион → Добавить язык.
                        Включите опцию «Распознавание рукописного ввода» — она содержит OCR.
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Горячие клавиши" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Включить/выключить перевод:"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding ToggleTranslationHotkey, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Показать/скрыть оверлей:"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding ToggleOverlayHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>

            <Button Content="Сохранить настройки"
                    Command="{Binding SaveCommand}"
                    Padding="20,10" FontWeight="SemiBold"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource PrimaryForegroundBrush}"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
