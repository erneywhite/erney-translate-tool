<UserControl x:Class="ErneyTranslateTool.Views.Tabs.TranslationSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ErneyTranslateTool.Views.Tabs"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="SettingsGroupBoxStyle" TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SettingsLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SettingsDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="20">
        <StackPanel>
            <TextBlock Text="Настройки перевода" 
                      FontSize="24" 
                      FontWeight="Bold"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,0,20"/>

            <!-- Секция: Сервис перевода -->
            <GroupBox Header="Сервис перевода" Style="{StaticResource SettingsGroupBoxStyle}">
                <StackPanel>
                    <TextBlock Text="Выберите сервис для перевода текста:" Style="{StaticResource SettingsDescriptionStyle}"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Сервис:" Style="{StaticResource SettingsLabelStyle}"/>
                        <ComboBox Grid.Column="1" 
                                 ItemsSource="{Binding TranslationProviders}"
                                 SelectedItem="{Binding SelectedTranslationProvider}"
                                 Style="{DynamicResource DarkComboBoxStyle}"/>
                    </Grid>

                    <TextBlock Text="API ключи (при необходимости):" Style="{StaticResource SettingsDescriptionStyle}"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Google API:" Style="{StaticResource SettingsLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                Text="{Binding GoogleApiKey, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource DarkTextBoxStyle}"
                                Margin="0,0,10,5"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Проверить" 
                               Command="{Binding TestApiCommand}"
                               CommandParameter="Google"
                               Style="{DynamicResource DarkButtonStyle}"
                               Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="DeepL API:" Style="{StaticResource SettingsLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                Text="{Binding DeeplApiKey, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource DarkTextBoxStyle}"
                                Margin="0,0,10,5"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="Проверить" 
                               Command="{Binding TestApiCommand}"
                               CommandParameter="DeepL"
                               Style="{DynamicResource DarkButtonStyle}"
                               Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Yandex API:" Style="{StaticResource SettingsLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" 
                                Text="{Binding YandexApiKey, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource DarkTextBoxStyle}"
                                Margin="0,0,10,0"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="Проверить" 
                               Command="{Binding TestApiCommand}"
                               CommandParameter="Yandex"
                               Style="{DynamicResource DarkButtonStyle}"/>
                    </Grid>

                    <TextBlock Text="{Binding TestApiStatus}" 
                              Foreground="{Binding TestApiSuccess, Converter={StaticResource BoolToColorConverter}}"
                              Margin="0,10,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Секция: Настройки захвата -->
            <GroupBox Header="Настройки захвата" Style="{StaticResource SettingsGroupBoxStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Задержка захвата (мс):" Style="{StaticResource SettingsLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                Text="{Binding CaptureDelay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{DynamicResource DarkTextBoxStyle}"
                                HorizontalAlignment="Left"
                                Width="100"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Формат изображения:" Style="{StaticResource SettingsLabelStyle}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" 
                                 Text="{Binding CaptureFormat}"
                                 Style="{DynamicResource DarkComboBoxStyle}"
                                 HorizontalAlignment="Left"
                                 Width="100">
                            <ComboBoxItem Content="PNG"/>
                            <ComboBoxItem Content="JPEG"/>
                            <ComboBoxItem Content="BMP"/>
                        </ComboBox>

                        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                 Content="Захватывать курсор"
                                 IsChecked="{Binding CaptureCursor}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,10,0,0"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Секция: Настройки OCR -->
            <GroupBox Header="Настройки распознавания (OCR)" Style="{StaticResource SettingsGroupBoxStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Движок OCR:" Style="{StaticResource SettingsLabelStyle}"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" 
                                 Text="{Binding SelectedOcrEngine}"
                                 Style="{DynamicResource DarkComboBoxStyle}"
                                 HorizontalAlignment="Left"
                                 Width="200">
                            <ComboBoxItem Content="Tesseract"/>
                            <ComboBoxItem Content="Windows.Media.OCR"/>
                            <ComboBoxItem Content="Google Vision"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Масштабирование:" Style="{StaticResource SettingsLabelStyle}"/>
                        <Grid Grid.Row="1" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" 
                                    Text="{Binding OcrScaleFactor, UpdateSourceTrigger=PropertyChanged}"
                                    Style="{DynamicResource DarkTextBoxStyle}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="x (рекомендуется 2-3)" 
                                      VerticalAlignment="Center"
                                      Margin="10,0,0,0"
                                      Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>

                        <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                 Content="Предварительная обработка изображения (улучшение качества)"
                                 IsChecked="{Binding OcrPreprocessImage}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 Margin="0,10,0,0"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Секция: Автоперевод -->
            <GroupBox Header="Автоперевод" Style="{StaticResource SettingsGroupBoxStyle}">
                <StackPanel>
                    <CheckBox Content="Автоматически переводить после захвата"
                             IsChecked="{Binding AutoTranslateAfterCapture}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Margin="0,0,0,10"/>

                    <CheckBox Content="Показывать перевод в оверлее"
                             IsChecked="{Binding ShowTranslationInOverlay}"
                             Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
