<UserControl x:Class="ErneyTranslateTool.Views.Tabs.TranslationSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="Настройки перевода"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,20"/>

            <GroupBox Header="Сервис перевода" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="Выбери сервис:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Providers}"
                              SelectedValue="{Binding SelectedProvider}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ProviderHelpText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding IsDeepL, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="API-ключ DeepL:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding DeepLApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsMyMemory, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Email (необязательно — увеличивает лимит до 50 000 симв./день):"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding MyMemoryEmail, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsGoogleFree, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Никаких настроек не требуется — нажми «Проверить» чтобы убедиться что endpoint доступен."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsLibre, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="URL инстанса:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LibreUrl, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="API-ключ (если требуется):" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LibreApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                    </StackPanel>

                    <Button Content="Проверить соединение"
                            Command="{Binding TestProviderCommand}"
                            Padding="14,8" HorizontalAlignment="Left"
                            Margin="0,12,0,8"/>

                    <TextBlock Text="{Binding TestStatus}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Целевой язык перевода" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <ComboBox ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding SelectedTargetLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="280" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Распознавание текста (OCR)" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="Движок распознавания:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OcrEngines}"
                              SelectedValue="{Binding SelectedOcrEngine}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="Язык распознавания (укажи язык игры):"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OcrLanguages}"
                              SelectedItem="{Binding SelectedOcrLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="320" HorizontalAlignment="Left"
                              Margin="0,0,0,10"/>

                    <!-- Windows OCR specific help -->
                    <StackPanel Visibility="{Binding IsWindowsOcr, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8">
                            Windows OCR работает только с установленными системными пакетами.
                            Если нужного языка нет в списке — установи через параметры Windows.
                        </TextBlock>
                        <Button Content="Открыть параметры языков Windows"
                                Command="{Binding OpenWindowsLanguageSettingsCommand}"
                                Padding="14,6" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Tesseract specific: catalog with download -->
                    <StackPanel Visibility="{Binding IsTesseract, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8">
                            Tesseract: английский, русский и японский встроены сразу. Любой
                            другой язык можно скачать одной кнопкой (источник — официальный
                            репозиторий tesseract-ocr/tessdata).
                        </TextBlock>

                        <CheckBox Content="Скачивать модели в улучшенном качестве (best, ~5x больше файлы — 15–25 МБ на язык)"
                                  IsChecked="{Binding UseBestTessdata}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="Чтобы заменить уже установленный пакет качественной версией — нажми «Удалить», включи галочку и скачай снова."
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="22,0,0,10"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Background="{DynamicResource InputBackgroundBrush}" Padding="6">
                            <ItemsControl ItemsSource="{Binding TessdataCatalog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text=" — "
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Code}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           Margin="10,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SizeText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,8,0"/>

                                            <Grid Grid.Column="2">
                                                <Button Content="Скачать"
                                                        Padding="10,4"
                                                        Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}"
                                                        Command="{Binding DataContext.DownloadLanguageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Удалить"
                                                        Padding="10,4"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                                        Command="{Binding DataContext.DeleteLanguageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Горячие клавиши" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Включить/выключить перевод:"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding ToggleTranslationHotkey, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Показать/скрыть оверлей:"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding ToggleOverlayHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Сохранить настройки"
                        Command="{Binding SaveCommand}"
                        Padding="20,10" FontWeight="SemiBold"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="{DynamicResource SuccessBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
