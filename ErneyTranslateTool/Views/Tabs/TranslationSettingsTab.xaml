<UserControl x:Class="ErneyTranslateTool.Views.Tabs.TranslationSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,20">
        <StackPanel>
            <TextBlock Text="Настройки перевода"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,20"/>

            <GroupBox Header="Сервис перевода" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="Выбери сервис:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Providers}"
                              SelectedValue="{Binding SelectedProvider}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ProviderHelpText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding IsDeepL, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="API-ключ DeepL:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding DeepLApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsMyMemory, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Email (необязательно — увеличивает лимит до 50 000 симв./день):"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding MyMemoryEmail, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsGoogleFree, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Никаких настроек не требуется — нажми «Проверить» чтобы убедиться что endpoint доступен."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsLibre, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="URL инстанса:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LibreUrl, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="API-ключ (если требуется):" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LibreApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsOpenAI, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="API-ключ OpenAI (sk-...):" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding OpenAIApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="Модель:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding OpenAIModelPresets}"
                                  Text="{Binding OpenAIModel, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Width="280"
                                  HorizontalAlignment="Left"
                                  ToolTipService.ToolTip="Можно выбрать из списка или вписать любую другую модель OpenAI"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsAnthropic, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="API-ключ Anthropic (sk-ant-...):" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding AnthropicApiKey, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="Модель:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AnthropicModelPresets}"
                                  Text="{Binding AnthropicModel, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Width="280"
                                  HorizontalAlignment="Left"
                                  ToolTipService.ToolTip="Можно выбрать из списка или вписать любую другую модель Anthropic"/>
                    </StackPanel>

                    <!-- Temperature + context controls — common to both LLM providers. -->
                    <StackPanel Visibility="{Binding IsLlm, Converter={StaticResource BoolToVis}}"
                                Margin="0,12,0,0">
                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8">
                            Параметры ниже общие для OpenAI и Anthropic — задаются здесь и применяются к тому,
                            что выбрано как основной провайдер выше.
                        </TextBlock>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Температура:"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       ToolTipService.ToolTip="0 = одинаковый перевод каждый раз, 1 = более свободный/креативный. Для перевода обычно 0.2–0.4."/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                    TickFrequency="0.1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    Value="{Binding LlmTemperature}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LlmTemperature, StringFormat={}{0:F2}}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <CheckBox Content="Передавать контекст последних реплик"
                                  IsChecked="{Binding LlmUseContext}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="0,0,0,4"
                                  ToolTipService.ToolTip="Помогает LLM правильно обрабатывать местоимения и продолжающиеся диалоги"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Размер контекста:"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       ToolTipService.ToolTip="Сколько предыдущих переводов передавать каждый раз. Больше = лучше контекст, но дороже"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="10" SmallChange="1" LargeChange="2"
                                    TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    Value="{Binding LlmContextSize}"
                                    IsEnabled="{Binding LlmUseContext}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LlmContextSize}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <Button Content="Проверить соединение"
                            Command="{Binding TestProviderCommand}"
                            Padding="14,8" HorizontalAlignment="Left"
                            Margin="0,12,0,8"/>

                    <TextBlock Text="{Binding TestStatus}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Резервный провайдер" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,8">
                        Если основной провайдер не отвечает несколько запросов подряд (упал, лимит исчерпан, нет интернета),
                        программа автоматически переключится на резервный. Каждую минуту пробует основной снова —
                        как только он восстановится, возвращается к нему. Учётные данные у обоих провайдеров общие
                        (DeepL ключ, MyMemory email, LibreTranslate URL/ключ) — задаются в блоке выше.
                    </TextBlock>
                    <ComboBox ItemsSource="{Binding FallbackProviders}"
                              SelectedValue="{Binding SelectedFallbackProvider}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Width="380"
                              HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Целевой язык перевода" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <ComboBox ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding SelectedTargetLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="280" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Распознавание текста (OCR)" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="Движок распознавания:" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OcrEngines}"
                              SelectedValue="{Binding SelectedOcrEngine}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6"
                            Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     Fill="{Binding OcrStatusColor}"/>
                            <TextBlock Text="{Binding OcrStatus}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Язык распознавания (укажи язык игры):"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OcrLanguages}"
                              SelectedItem="{Binding SelectedOcrLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="320" HorizontalAlignment="Left"
                              Margin="0,0,0,10"/>

                    <!-- Windows OCR specific help -->
                    <StackPanel Visibility="{Binding IsWindowsOcr, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8">
                            Windows OCR работает только с установленными системными пакетами.
                            Если нужного языка нет в списке — установи через параметры Windows.
                        </TextBlock>
                        <Button Content="Открыть параметры языков Windows"
                                Command="{Binding OpenWindowsLanguageSettingsCommand}"
                                Padding="14,6" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Tesseract specific: catalog with download -->
                    <StackPanel Visibility="{Binding IsTesseract, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8">
                            Tesseract: английский, русский и японский встроены сразу. Любой
                            другой язык можно скачать одной кнопкой (источник — официальный
                            репозиторий tesseract-ocr/tessdata).
                        </TextBlock>

                        <CheckBox Content="Скачивать модели в улучшенном качестве (best, ~5x больше файлы — 15–25 МБ на язык)"
                                  IsChecked="{Binding UseBestTessdata}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="Чтобы заменить уже установленный пакет качественной версией — нажми «Удалить», включи галочку и скачай снова."
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="22,0,0,10"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Background="{DynamicResource InputBackgroundBrush}" Padding="6">
                            <ItemsControl ItemsSource="{Binding TessdataCatalog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text=" — "
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Code}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           Margin="10,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SizeText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,8,0"/>

                                            <Grid Grid.Column="2">
                                                <Button Content="Скачать"
                                                        Padding="10,4"
                                                        Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}"
                                                        Command="{Binding DataContext.DownloadLanguageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Удалить"
                                                        Padding="10,4"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                                        Command="{Binding DataContext.DeleteLanguageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- Paddle specific help -->
                    <StackPanel Visibility="{Binding IsPaddle, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8">
                            PaddleOCR — нейросетевой движок, заметно точнее Tesseract на стилизованных
                            и мелких шрифтах. На 1080p один кадр обрабатывается ~1-2 сек (вдвое медленнее
                            Tesseract). При первом выборе языка модель (~10-20 МБ) скачается с интернета
                            и закэшируется — дальше работает офлайн.
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Кэш переводов" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10">
                        Все переведённые фразы сохраняются в локальный кэш — повторное появление того же
                        текста (диалог, меню, описание квеста) подтягивается из кэша моментально, без
                        запроса к сервису перевода. При превышении лимита удаляются самые давно неиспользуемые записи.
                    </TextBlock>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Максимальный размер:"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding CacheSizeOptions}"
                                  SelectedItem="{Binding SelectedCacheSizeOption}"
                                  DisplayMemberPath="DisplayName"
                                  Width="260"
                                  HorizontalAlignment="Left"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Текущее состояние: "
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CacheStatsText}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Обновить"
                                Command="{Binding RefreshCacheStatsCommand}"
                                Padding="14,6" Margin="0,0,8,0"/>
                        <Button Content="Очистить кэш"
                                Command="{Binding ClearCacheCommand}"
                                Padding="14,6"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Горячие клавиши" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Включить/выключить перевод:"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding ToggleTranslationHotkey, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Показать/скрыть оверлей:"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding ToggleOverlayHotkey, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Сохранить настройки"
                        Command="{Binding SaveCommand}"
                        Padding="20,10" FontWeight="SemiBold"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="{DynamicResource SuccessBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
