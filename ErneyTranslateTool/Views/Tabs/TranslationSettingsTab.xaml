<UserControl x:Class="ErneyTranslateTool.Views.Tabs.TranslationSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:ErneyTranslateTool.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,20">
        <StackPanel>
            <TextBlock Text="{DynamicResource Strings.TS.Title}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,20"/>

            <GroupBox Header="{DynamicResource Strings.TS.Service}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="{DynamicResource Strings.TS.SelectService}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Providers}"
                              SelectedValue="{Binding SelectedProvider}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding ProviderHelpText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>

                    <StackPanel Visibility="{Binding IsDeepL, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.DeepLKey}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <controls:MaskedSecretBox Secret="{Binding DeepLApiKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsMyMemory, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.MyMemoryEmail}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding MyMemoryEmail, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsGoogleFree, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.GoogleHelp}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsLibre, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.LibreUrl}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding LibreUrl, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Consolas"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Strings.TS.LibreKey}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <controls:MaskedSecretBox Secret="{Binding LibreApiKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsOpenAI, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.OpenAIKey}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <controls:MaskedSecretBox Secret="{Binding OpenAIApiKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Strings.TS.Model}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding OpenAIModel, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     Margin="0,0,8,0"
                                     ToolTip="{DynamicResource Strings.TS.ModelTextHint}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding OpenAIModelPresets}"
                                      SelectedItem="{Binding OpenAIModel, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="{DynamicResource Strings.TS.ModelPresetsHint}"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsAnthropic, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.AnthropicKey}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <controls:MaskedSecretBox Secret="{Binding AnthropicApiKey, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource Strings.TS.Model}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding AnthropicModel, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"
                                     Margin="0,0,8,0"
                                     ToolTip="{DynamicResource Strings.TS.ModelTextHint}"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AnthropicModelPresets}"
                                      SelectedItem="{Binding AnthropicModel, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="{DynamicResource Strings.TS.ModelPresetsHint}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Temperature + context controls — common to both LLM providers. -->
                    <StackPanel Visibility="{Binding IsLlm, Converter={StaticResource BoolToVis}}"
                                Margin="0,12,0,0">
                        <TextBlock Text="{DynamicResource Strings.TS.LlmHelp}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Strings.TS.Temperature}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       ToolTip="{DynamicResource Strings.TS.Temperature.Tooltip}"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1"
                                    TickFrequency="0.1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    Value="{Binding LlmTemperature}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LlmTemperature, StringFormat={}{0:F2}}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <CheckBox Content="{DynamicResource Strings.TS.UseContext}"
                                  IsChecked="{Binding LlmUseContext}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="0,0,0,4"
                                  ToolTip="{DynamicResource Strings.TS.UseContext.Tooltip}"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Strings.TS.ContextSize}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       ToolTip="{DynamicResource Strings.TS.ContextSize.Tooltip}"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="10" SmallChange="1" LargeChange="2"
                                    TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                    Value="{Binding LlmContextSize}"
                                    IsEnabled="{Binding LlmUseContext}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding LlmContextSize}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <Button Content="{DynamicResource Strings.TS.TestConnection}"
                            Command="{Binding TestProviderCommand}"
                            Padding="14,8" HorizontalAlignment="Left"
                            Margin="0,12,0,8"/>

                    <TextBlock Text="{Binding TestStatus}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.TS.Fallback}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="{DynamicResource Strings.TS.FallbackHelp}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding FallbackProviders}"
                              SelectedValue="{Binding SelectedFallbackProvider}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Width="380"
                              HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.TS.TargetLang}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <ComboBox ItemsSource="{Binding TargetLanguages}"
                              SelectedItem="{Binding SelectedTargetLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="280" HorizontalAlignment="Left"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.TS.OcrSection}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="{DynamicResource Strings.TS.OcrEngine}" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OcrEngines}"
                              SelectedValue="{Binding SelectedOcrEngine}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,6"
                            Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     Fill="{Binding OcrStatusColor}"/>
                            <TextBlock Text="{Binding OcrStatus}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{DynamicResource Strings.TS.OcrLang}"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding OcrLanguages}"
                              SelectedItem="{Binding SelectedOcrLanguage}"
                              DisplayMemberPath="DisplayName"
                              Width="320" HorizontalAlignment="Left"
                              Margin="0,0,0,10"/>

                    <!-- Windows OCR specific help -->
                    <StackPanel Visibility="{Binding IsWindowsOcr, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.WindowsOcrHelp}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        <Button Content="{DynamicResource Strings.TS.OpenWindowsLang}"
                                Command="{Binding OpenWindowsLanguageSettingsCommand}"
                                Padding="14,6" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Tesseract specific: catalog with download -->
                    <StackPanel Visibility="{Binding IsTesseract, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.TesseractHelp}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>

                        <CheckBox Content="{DynamicResource Strings.TS.TessdataBest}"
                                  IsChecked="{Binding UseBestTessdata}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="{DynamicResource Strings.TS.TessdataBestHint}"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="22,0,0,10"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4"
                                Background="{DynamicResource InputBackgroundBrush}" Padding="6">
                            <ItemsControl ItemsSource="{Binding TessdataCatalog}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text=" — "
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Code}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           Margin="10,0,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SizeText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,0,8,0"/>

                                            <Grid Grid.Column="2">
                                                <Button Content="{DynamicResource Strings.TS.DownloadLang}"
                                                        Padding="10,4"
                                                        Visibility="{Binding CanDownload, Converter={StaticResource BoolToVis}}"
                                                        Command="{Binding DataContext.DownloadLanguageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="{DynamicResource Strings.Common.Delete}"
                                                        Padding="10,4"
                                                        Background="Transparent"
                                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                                        Command="{Binding DataContext.DeleteLanguageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- Paddle specific help -->
                    <StackPanel Visibility="{Binding IsPaddle, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource Strings.TS.PaddleHelp}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.TS.Cache}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <TextBlock Text="{DynamicResource Strings.TS.CacheHelp}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource Strings.TS.CacheLimit}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding CacheSizeOptions}"
                                  SelectedItem="{Binding SelectedCacheSizeOption}"
                                  DisplayMemberPath="DisplayName"
                                  Width="260"
                                  HorizontalAlignment="Left"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{DynamicResource Strings.TS.CacheCurrent}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CacheStatsText}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="{DynamicResource Strings.Common.Refresh}"
                                Command="{Binding RefreshCacheStatsCommand}"
                                Padding="14,6" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource Strings.TS.ClearCache}"
                                Command="{Binding ClearCacheCommand}"
                                Padding="14,6"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.TS.Hotkeys}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="5">
                    <!-- v1.0.14: HotkeyCaptureBox replaces the old plain TextBox.
                         Click → press combo → it's saved AND re-registered with
                         Win32 immediately (no restart needed — that was the
                         "I changed it but it doesn't work" v1.0.13 bug). -->
                    <TextBlock Text="{DynamicResource Strings.TS.HotkeysHelp}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Strings.TS.HotkeyToggle}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <controls:HotkeyCaptureBox Grid.Row="0" Grid.Column="1"
                                                   Hotkey="{Binding ToggleTranslationHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Strings.TS.HotkeyOverlay}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <controls:HotkeyCaptureBox Grid.Row="1" Grid.Column="1"
                                                   Hotkey="{Binding ToggleOverlayHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Strings.TS.HotkeyPause}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <controls:HotkeyCaptureBox Grid.Row="2" Grid.Column="1"
                                                   Hotkey="{Binding PauseTranslationHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{DynamicResource Strings.TS.SaveBtn}"
                        Command="{Binding SaveCommand}"
                        Padding="20,10" FontWeight="SemiBold"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="{DynamicResource SuccessBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
