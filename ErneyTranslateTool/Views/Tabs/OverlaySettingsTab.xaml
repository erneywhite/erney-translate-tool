<UserControl x:Class="ErneyTranslateTool.Views.Tabs.OverlaySettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock Text="Настройки оверлея"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,20"/>

            <GroupBox Header="Внешний вид" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Шрифт:"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                              ItemsSource="{Binding SystemFonts}"
                              SelectedItem="{Binding OverlayFontFamily}"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Режим размера шрифта:"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                              ItemsSource="{Binding FontSizeModes}"
                              SelectedItem="{Binding FontSizeMode}"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Размер шрифта (вручную):"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Slider Grid.Row="2" Grid.Column="1"
                            Minimum="8" Maximum="32"
                            Value="{Binding ManualFontSize}"
                            Margin="0,0,8,8"/>
                    <TextBlock Grid.Row="2" Grid.Column="2"
                               Text="{Binding ManualFontSize, StringFormat={}{0:F0}}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Прозрачность фона:"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Slider Grid.Row="3" Grid.Column="1"
                            Minimum="0.6" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True"
                            Value="{Binding OverlayOpacity}"
                            Margin="0,0,8,8"/>
                    <TextBlock Grid.Row="3" Grid.Column="2"
                               Text="{Binding OverlayOpacity, StringFormat={}{0:P0}}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Цвет фона (HEX):"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                             Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Цвет текста (HEX):"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                             Text="{Binding TextColor, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Предпросмотр" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Border Background="{Binding BackgroundColor}"
                        Padding="12" CornerRadius="4"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <TextBlock Text="Пример переведённого текста"
                               Foreground="{Binding TextColor}"
                               FontFamily="{Binding OverlayFontFamily}"
                               FontSize="{Binding ManualFontSize}"/>
                </Border>
            </GroupBox>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Сохранить настройки"
                        Command="{Binding SaveCommand}"
                        Padding="20,10" FontWeight="SemiBold"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource PrimaryForegroundBrush}"/>
                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="{DynamicResource SuccessBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
