<UserControl x:Class="ErneyTranslateTool.Views.Tabs.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40">
        <StackPanel MaxWidth="700">
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                <TextBlock Text="Erney's Translate Tool"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Версия 1.0.0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <GroupBox Header="О программе" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <TextBlock Margin="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}">
                    Инструмент для перевода текста с экрана в реальном времени. Захватывает указанное окно,
                    распознаёт текст через Windows.Media.OCR и переводит его через DeepL API. Перевод
                    отображается полупрозрачным оверлеем поверх оригинала.
                </TextBlock>
            </GroupBox>

            <GroupBox Header="Горячие клавиши" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Включить/выключить перевод:"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Ctrl + Shift + T"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Показать/скрыть оверлей:"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl + Shift + H"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Системные требования" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <TextBlock Margin="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}">
                    <Run FontWeight="Bold">ОС:</Run> Windows 10/11 (x64)<LineBreak/>
                    <Run FontWeight="Bold">.NET:</Run> .NET 8.0 Runtime<LineBreak/>
                    <Run FontWeight="Bold">Память:</Run> 512 МБ ОЗУ<LineBreak/>
                    <Run FontWeight="Bold">Место на диске:</Run> 100 МБ
                </TextBlock>
            </GroupBox>

            <Border Background="#3D3D1A1A"
                    BorderBrush="#FFD32F2F"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="15"
                    Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Важное предупреждение"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#FFFFB74D"
                               Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}">
                        Программа использует стандартный Windows API захвата экрана и не модифицирует
                        память игр. Тем не менее, использование в онлайн-играх с античитом может
                        нарушать условия использования игры. Используйте на свой страх и риск.
                    </TextBlock>
                </StackPanel>
            </Border>

            <TextBlock Text="© 2026 Erney White. MIT License."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
