<UserControl x:Class="ErneyTranslateTool.Views.Tabs.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40">
        <StackPanel MaxWidth="780">

            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,25">
                <TextBlock Text="Erney's Translate Tool"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Версия 1.0.2 · MIT License"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Button Content="Проверить обновление"
                            Padding="14,6" Margin="0,0,8,0"
                            Click="OnCheckUpdatesClick"/>
                    <Button Content="GitHub репозиторий"
                            Padding="14,6"
                            Click="OnOpenRepoClick"/>
                </StackPanel>
            </StackPanel>

            <GroupBox Header="Что это" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <TextBlock Margin="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}">
                    Программа в реальном времени распознаёт текст в выбранном окне (игра, видео, любой
                    софт), переводит его и накладывает русский перевод поверх оригинала прозрачной
                    «табличкой». Управление — мышью или горячими клавишами; клики проходят сквозь
                    оверлей, играть/работать можно как обычно.
                </TextBlock>
            </GroupBox>

            <GroupBox Header="Быстрый старт" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">1.</Run>
                        Запусти игру (оконный или borderless-режим — полный экран не подходит).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">2.</Run>
                        Вкладка <Run FontWeight="SemiBold">«Главная»</Run> → нажми «Обновить список» →
                        выбери окно игры → нажми «Запустить» (или Ctrl+Shift+T).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">3.</Run>
                        В игре появятся переводы поверх английского текста. Игру можно тыкать как обычно.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}">4.</Run>
                        Чтобы остановить — снова Ctrl+Shift+T или кнопка «Остановить» в программе.
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Горячие клавиши" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Включить/выключить перевод:"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Ctrl + Shift + T"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Показать/скрыть оверлей:"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl + Shift + H"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Что внутри" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8">
                        <Run FontWeight="Bold">Распознавание (OCR):</Run>
                        Три движка на выбор —
                        <Run FontWeight="SemiBold">PaddleOCR</Run> (нейросеть, по умолчанию, лучшая точность),
                        <Run FontWeight="SemiBold">Tesseract</Run> (быстрее, средняя точность),
                        <Run FontWeight="SemiBold">Windows OCR</Run> (нужны системные языковые пакеты).
                        12 языков для PaddleOCR (включая режим «Авто» — англ+яп+кириллица одновременно).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8">
                        <Run FontWeight="Bold">Перевод:</Run>
                        Четыре сервиса —
                        <Run FontWeight="SemiBold">MyMemory</Run> (бесплатно, без регистрации),
                        <Run FontWeight="SemiBold">Google Translate</Run> (бесплатно, без ключа),
                        <Run FontWeight="SemiBold">DeepL</Run> (нужен ключ),
                        <Run FontWeight="SemiBold">LibreTranslate</Run> (open source, любой инстанс).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run FontWeight="Bold">Захват экрана:</Run>
                        Windows API <Run FontFamily="Consolas">PrintWindow</Run> с флагом
                        RENDERFULLCONTENT — работает с современными играми, Chromium-браузерами и UWP.
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Где хранятся файлы программы" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8">
                        Все данные хранятся рядом с программой (или в
                        <Run FontFamily="Consolas">%AppData%\ErneyTranslateTool</Run> если папка только для чтения):
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas">
                        settings.json — настройки<LineBreak/>
                        cache.db — кэш переводов<LineBreak/>
                        history.db — история сессий<LineBreak/>
                        logs\ — журналы работы<LineBreak/>
                        tessdata\ — модели Tesseract<LineBreak/>
                        Sdcb.PaddleOCR кэш — модели PaddleOCR (в %LocalAppData%\Sdcb)
                    </TextBlock>
                </StackPanel>
            </GroupBox>

            <Border Background="#FFFBE6"
                    BorderBrush="#F59E0B"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="☕  Понравилась программа?"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#78350F"/>
                        <TextBlock Text="Программа полностью бесплатная и open-source. Если хочется поддержать разработку — можно угостить кофе."
                                   Foreground="#92400E"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            VerticalAlignment="Center"
                            Padding="18,12"
                            Margin="20,0,0,0"
                            FontWeight="Bold"
                            FontSize="14"
                            Background="#F59E0B"
                            Foreground="#FFFFFF"
                            BorderBrush="#D97706"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="OnDonateClick"
                            ToolTip="Откроет страницу с вариантами поддержки в браузере">
                        ☕  Купить мне кофе
                    </Button>
                </Grid>
            </Border>

            <Border Background="#3D3D1A1A"
                    BorderBrush="#FFD32F2F"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="15"
                    Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="⚠ Важно про онлайн-игры"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#FFFFB74D"
                               Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}">
                        Программа использует только стандартные Windows API захвата окна и не лезет в
                        память игр. Тем не менее в онлайн-играх с античитом (Vanguard, EAC, BattlEye,
                        Ricochet и т.п.) использование любых внешних программ может нарушать правила
                        игры — на свой страх и риск. Для одиночных игр и визуальных новелл — полностью
                        безопасно.
                    </TextBlock>
                </StackPanel>
            </Border>

            <GroupBox Header="Системные требования" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <TextBlock Margin="10" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}">
                    Windows 10 1809+ или Windows 11 (x64) · .NET 8 Runtime · ~2 ГБ ОЗУ свободно (для
                    PaddleOCR) · Visual C++ Redistributable 2015-2022.
                </TextBlock>
            </GroupBox>

            <TextBlock Text="© 2026 Erney White · github.com/erneywhite/erney-translate-tool"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
