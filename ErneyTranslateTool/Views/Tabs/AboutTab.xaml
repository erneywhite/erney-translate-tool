<UserControl x:Class="ErneyTranslateTool.Views.Tabs.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,20">
        <StackPanel MaxWidth="780">

            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,25">
                <TextBlock Text="Erney's Translate Tool"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Strings.About.Subtitle}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Button Content="{DynamicResource Strings.About.CheckUpdates}"
                            Padding="14,6" Margin="0,0,8,0"
                            Click="OnCheckUpdatesClick"/>
                    <Button Content="{DynamicResource Strings.About.GitHub}"
                            Padding="14,6"
                            Click="OnOpenRepoClick"/>
                </StackPanel>
            </StackPanel>

            <GroupBox Header="{DynamicResource Strings.About.WhatIs}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <TextBlock Margin="10" TextWrapping="Wrap"
                           Text="{DynamicResource Strings.About.WhatIsBody}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.About.QuickStart}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock Text="{DynamicResource Strings.About.QuickStartStep1}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Strings.About.QuickStartStep2}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Strings.About.QuickStartStep3}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Strings.About.QuickStartStep4}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.About.HotkeysGroup}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Strings.About.HotkeyToggle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Ctrl + Shift + T"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource Strings.About.HotkeyOverlay}"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl + Shift + H"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Margin="0,8,0,0"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.About.WhatInside}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock Text="{DynamicResource Strings.About.OcrInside}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Strings.About.TranslateInside}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Strings.About.CaptureInside}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{DynamicResource Strings.About.FilesGroup}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock Text="{DynamicResource Strings.About.FilesIntro}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Strings.About.FilesList}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas"/>
                </StackPanel>
            </GroupBox>

            <Border Background="#FFFBE6"
                    BorderBrush="#F59E0B"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Strings.About.DonateGroupTitle}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#78350F"/>
                        <TextBlock Text="{DynamicResource Strings.About.DonateGroupBody}"
                                   Foreground="#92400E"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="{DynamicResource Strings.About.DonateButton}"
                            VerticalAlignment="Center"
                            Padding="18,12"
                            Margin="20,0,0,0"
                            FontWeight="Bold"
                            FontSize="14"
                            Background="#F59E0B"
                            Foreground="#FFFFFF"
                            BorderBrush="#D97706"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="OnDonateClick"
                            ToolTip="{DynamicResource Strings.About.DonateTooltip}"/>
                </Grid>
            </Border>

            <Border Background="#3D3D1A1A"
                    BorderBrush="#FFD32F2F"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="15"
                    Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Strings.About.OnlineWarningTitle}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#FFFFB74D"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Strings.About.OnlineWarningBody}"
                               TextWrapping="Wrap" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <GroupBox Header="{DynamicResource Strings.About.SystemReqs}" Style="{DynamicResource DarkGroupBoxStyle}" Margin="0,0,0,15">
                <TextBlock Margin="10" TextWrapping="Wrap"
                           Text="{DynamicResource Strings.About.SystemReqsBody}"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </GroupBox>

            <TextBlock Text="{DynamicResource Strings.About.Footer}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
