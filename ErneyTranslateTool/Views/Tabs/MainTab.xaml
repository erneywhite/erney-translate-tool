<UserControl x:Class="ErneyTranslateTool.Views.Tabs.MainTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Главная"
                   FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,15"/>

        <GroupBox Grid.Row="2" Header="Окно для перевода"
                  Style="{DynamicResource DarkGroupBoxStyle}"
                  Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="Выбери окно игры/программы из списка ниже. Игра должна быть запущена в оконном или borderless-режиме (полный экран не подходит)."
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Обновить список"
                            Command="{Binding RefreshWindowsCommand}"
                            Padding="12,6" Margin="0,0,10,0"
                            ToolTip="Пересканировать список открытых окон"/>
                    <TextBlock Text="Выбрано: " VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SelectedWindowTitle}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Windows}"
                         SelectedItem="{Binding SelectedWindow}"
                         Background="{DynamicResource InputBackgroundBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                <TextBlock Text=" — " Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="{Binding ToggleButtonText}"
                    Command="{Binding ToggleEngineCommand}"
                    Padding="20,10" FontWeight="SemiBold"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource PrimaryForegroundBrush}"
                    Margin="0,0,10,0"
                    ToolTip="Ctrl+Shift+T"/>
            <Button Content="Обновить статистику"
                    Command="{Binding RefreshStatsCommand}"
                    Padding="12,8"/>
        </StackPanel>

        <GroupBox Grid.Row="4" Header="Статистика"
                  Style="{DynamicResource DarkGroupBoxStyle}">
            <StackPanel Margin="5">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Переведено символов сегодня: "
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding CharactersTranslatedToday}"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Попадания в кэш: "
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding CacheHitRate, StringFormat={}{0:F1}%}"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Среднее время на фрейм: "
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               ToolTip="OCR + перевод + отрисовка оверлея, скользящее среднее"/>
                    <TextBlock Text="{Binding FrameTimeText}"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</UserControl>
