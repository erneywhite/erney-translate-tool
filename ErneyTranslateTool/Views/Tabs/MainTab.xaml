<UserControl x:Class="ErneyTranslateTool.Views.Tabs.MainTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ErneyTranslateTool.Views.Tabs"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
            <Setter Property="Padding" Value="15,8"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и статус -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Основной экран" 
                          FontSize="24" 
                          FontWeight="Bold"
                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                          FontSize="14"
                          Foreground="{DynamicResource TextSecondaryBrush}"
                          Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="⚙ Настройки" 
                       Command="{Binding OpenSettingsCommand}"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Margin="0,0,10,0"/>
                <Button Content="📜 История" 
                       Command="{Binding OpenHistoryCommand}"
                       Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Исходный текст -->
            <GroupBox Grid.Column="0" 
                     Header="Распознанный текст"
                     Style="{DynamicResource DarkGroupBoxStyle}"
                     Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                            Text="{Binding CapturedText, UpdateSourceTrigger=PropertyChanged}"
                            Style="{DynamicResource DarkTextBoxStyle}"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="📷 Захват области" 
                               Command="{Binding CaptureCommand}"
                               Style="{StaticResource PrimaryButtonStyle}"
                               ToolTip="Горячая клавиша: Ctrl+Alt+Z"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Кнопки управления -->
            <StackPanel Grid.Column="1" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Center"
                       Margin="10,0">
                <Button Content="➡ Перевести" 
                       Command="{Binding TranslateCommand}"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="0,0,0,10"
                       ToolTip="Горячая клавиша: Ctrl+Alt+X"/>

                <Button Content="📋 Копировать" 
                       Command="{Binding CopyTranslatedCommand}"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Margin="0,0,0,10"/>

                <Button Content="🗑 Очистить" 
                       Command="{Binding ClearTextCommand}"
                       Style="{StaticResource SecondaryButtonStyle}"
                       Margin="0,0,0,10"/>

                <Button Content="🔲 Оверлей" 
                       Command="{Binding ToggleOverlayCommand}"
                       Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>

            <!-- Переведённый текст -->
            <GroupBox Grid.Column="2" 
                     Header="Перевод"
                     Style="{DynamicResource DarkGroupBoxStyle}"
                     Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                            Text="{Binding TranslatedText, UpdateSourceTrigger=PropertyChanged}"
                            Style="{DynamicResource DarkTextBoxStyle}"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Индикатор перевода:" 
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,0,10,0"/>
                        <ProgressBar Width="100" 
                                    Height="10"
                                    IsIndeterminate="{Binding IsTranslating}"
                                    Visibility="{Binding IsTranslating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Панель выбора языков -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                      Text="С языка:" 
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,10,0"/>

            <ComboBox Grid.Column="1" 
                     ItemsSource="{Binding AvailableLanguages}"
                     SelectedValue="{Binding SelectedSourceLanguage}"
                     SelectedValuePath="Code"
                     DisplayMemberPath="Name"
                     Style="{DynamicResource DarkComboBoxStyle}"
                     Margin="0,0,20,0"/>

            <TextBlock Grid.Column="2" 
                      Text="➡" 
                      VerticalAlignment="Center"
                      FontSize="20"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      Margin="0,0,20,0"/>

            <TextBlock Grid.Column="3" 
                      Text="На язык:" 
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Margin="0,0,10,0"/>

            <ComboBox Grid.Column="4" 
                     ItemsSource="{Binding AvailableLanguages}"
                     SelectedValue="{Binding SelectedTargetLanguage}"
                     SelectedValuePath="Code"
                     DisplayMemberPath="Name"
                     Style="{DynamicResource DarkComboBoxStyle}"/>
        </Grid>
    </Grid>
</UserControl>
