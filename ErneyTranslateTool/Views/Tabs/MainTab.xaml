<UserControl x:Class="ErneyTranslateTool.Views.Tabs.MainTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="{DynamicResource BackgroundBrush}">

    <!-- v1.0.13 padding standardisation: every tab uses the same root
         layout — outer ScrollViewer with Padding="28,20,28,20" + a
         StackPanel of children. Title sits at the StackPanel's top so
         it lines up at the same x position as headings on every other
         tab. Internal two-column dashboard for cards lives below. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20,28,20">
        <StackPanel>
            <TextBlock Text="{DynamicResource Strings.Main.Title}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,18"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Window picker card (left column) -->
                <GroupBox Grid.Column="0"
                          Header="{DynamicResource Strings.Main.WindowGroup}"
                          Style="{DynamicResource DarkGroupBoxStyle}"
                          Margin="0,0,18,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{DynamicResource Strings.Main.WindowHelp}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="{DynamicResource Strings.Main.RefreshList}"
                                    Command="{Binding RefreshWindowsCommand}"
                                    Padding="14,8" Margin="0,0,12,0"
                                    ToolTip="{DynamicResource Strings.Main.RefreshList.Tooltip}"/>
                            <TextBlock Text="{DynamicResource Strings.Main.SelectedLabel}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SelectedWindowTitle}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                        </StackPanel>
                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding Windows}"
                                 SelectedItem="{Binding SelectedWindow}"
                                 Background="{DynamicResource InputBackgroundBrush}"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 MinHeight="240">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                        <TextBlock Text=" — " Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
                            <Button Content="{Binding ToggleButtonText}"
                                    Command="{Binding ToggleEngineCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    ToolTip="Ctrl+Shift+T"/>
                            <Button Content="{DynamicResource Strings.Main.RefreshStats}"
                                    Command="{Binding RefreshStatsCommand}"
                                    Padding="14,8" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Modern stat cards (right column) -->
                <StackPanel Grid.Column="1">
                    <Border Style="{DynamicResource ModernCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Strings.Main.CharsToday}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding CharactersTranslatedToday, StringFormat={}{0:N0}}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="32" FontWeight="Bold"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ModernCardStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Strings.Main.CacheHit}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding CacheHitRate, StringFormat={}{0:F1}%}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="32" FontWeight="Bold"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ModernCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Strings.Main.FrameTime}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       ToolTip="{DynamicResource Strings.Main.FrameTime.Tooltip}"/>
                            <TextBlock Text="{Binding FrameTimeText}"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="22" FontWeight="SemiBold"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
