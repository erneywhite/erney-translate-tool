<UserControl x:Class="ErneyTranslateTool.Views.Tabs.HistoryTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Strings.History.Title}"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{DynamicResource Strings.Common.Refresh}" Command="{Binding RefreshCommand}"
                        Padding="12,6" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource Strings.History.ExportSession}" Command="{Binding ExportSessionCommand}"
                        Padding="12,6" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource Strings.History.ClearAll}" Command="{Binding ClearHistoryCommand}"
                        Padding="12,6"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="{DynamicResource Strings.History.Search}" Command="{Binding SearchCommand}"
                    Padding="12,6"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Sessions}"
                     SelectedItem="{Binding SelectedSession}"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     Margin="0,0,10,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <TextBlock Text="{Binding WindowTitle}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding StartTime, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <DataGrid Grid.Column="1"
                      ItemsSource="{Binding SessionEntries}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      Background="{DynamicResource BackgroundBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      RowBackground="{DynamicResource BackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource AlternateRowBrush}"
                      BorderBrush="{DynamicResource BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource Strings.History.ColTime}" Width="120"
                                        Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"/>
                    <DataGridTextColumn Header="{DynamicResource Strings.History.ColLang}" Width="60"
                                        Binding="{Binding SourceLanguage}"/>
                    <DataGridTextColumn Header="{DynamicResource Strings.History.ColOriginal}" Width="*"
                                        Binding="{Binding OriginalText}"/>
                    <DataGridTextColumn Header="{DynamicResource Strings.History.ColTranslated}" Width="*"
                                        Binding="{Binding TranslatedText}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
