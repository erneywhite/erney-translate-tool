<Window x:Class="ErneyTranslateTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:ErneyTranslateTool.Views.Tabs"
        Title="Erney's Translate Tool"
        Height="720" Width="1080"
        MinHeight="540" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <!-- TextOptions above fix v1.0.12's "blurry text" regression: WPF's
         default "Ideal" formatting mode renders sub-pixel precise but
         visibly fuzzy at typical 100 % DPI. "Display" snaps to pixels,
         ClearType gives sharp anti-aliasing.
         UseLayoutRounding + SnapsToDevicePixels align all WPF geometry to
         whole pixels (border, text, shadows). -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar. Icons use Segoe MDL2 Assets (ships with Windows 10
             1803+) so glyphs render identically on every supported box —
             unlike emoji whose coverage depends on the installed
             colour-emoji font version. -->
        <Border Grid.Column="0"
                Background="{DynamicResource BackgroundDarkBrush}"
                Padding="0">
            <DockPanel LastChildFill="True">
                <!-- Brand area: app icon + wordmark. -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="14,18,14,14">
                    <!-- High-res PNG logo (256+ px source) downscaled to 36
                         with HighQuality interpolation. Replaces the
                         previous app.ico-based image which was visibly
                         soft because the embedded 32x32 ICO frame got
                         used directly. -->
                    <Image Source="pack://application:,,,/Resources/Icons/app-logo.png"
                           Width="36" Height="36"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Erney's"
                                   FontWeight="Bold" FontSize="15"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Translate Tool"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <ListBox x:Name="NavList"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         SelectionChanged="OnNavSelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="Margin" Value="6,2"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="b"
                                                CornerRadius="10"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryForegroundBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <!-- Icon glyphs: Segoe MDL2 Assets code points.
                         E80F=Home, F2B7=Dictionary, E790=PaintBrush,
                         E81C=History, E82D=Library, E748=Contact,
                         E713=Settings, E946=Info. -->
                    <ListBoxItem Tag="Main">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.Main}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Translation">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xF2B7;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.TranslationSettings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Overlay">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE790;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.OverlaySettings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="History">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE81C;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.History}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Glossary">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE82D;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.Glossary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Profiles">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE748;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.Profiles}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="AppSettings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.AppSettings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="About">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE946;" FontSize="14" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Strings.Tab.About}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content host: all tab UserControls stay loaded so their state
             (scroll positions, in-flight edits) survives navigation. -->
        <Grid Grid.Column="1">
            <tabs:MainTab x:Name="MainTabHost"
                          DataContext="{Binding MainVM}"
                          Visibility="Visible"/>
            <tabs:TranslationSettingsTab x:Name="TranslationTabHost"
                                         DataContext="{Binding SettingsVM}"
                                         Visibility="Collapsed"/>
            <tabs:OverlaySettingsTab x:Name="OverlayTabHost"
                                     DataContext="{Binding SettingsVM}"
                                     Visibility="Collapsed"/>
            <tabs:HistoryTab x:Name="HistoryTabHost"
                             DataContext="{Binding HistoryVM}"
                             Visibility="Collapsed"/>
            <tabs:GlossaryTab x:Name="GlossaryTabHost"
                              DataContext="{Binding GlossaryVM}"
                              Visibility="Collapsed"/>
            <tabs:ProfilesTab x:Name="ProfilesTabHost"
                              DataContext="{Binding ProfilesVM}"
                              Visibility="Collapsed"/>
            <tabs:AppSettingsTab x:Name="AppSettingsTabHost"
                                 DataContext="{Binding SettingsVM}"
                                 Visibility="Collapsed"/>
            <tabs:AboutTab x:Name="AboutTabHost"
                           Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
